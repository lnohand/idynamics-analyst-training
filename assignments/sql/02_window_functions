## Step F — Add LAG(): Complete Final Query

**Concept:** `LAG(col) OVER (ORDER BY col)` returns the value from the
previous row. For the first row, it returns NULL (there is no previous row).
You use this to show what last month's total was, and to calculate the
month-over-month change.

Add two columns to the SELECT from Step E:

```sql
LAG(total_mrr) OVER (ORDER BY month)                        AS prev_total_mrr,
ROUND(total_mrr - LAG(total_mrr) OVER (ORDER BY month), 2) AS mom_change
```

**Your query:** The complete Final query. This is the exact output you
export to Excel.

**Return:** `month`, `new_mrr`, `churned_mrr`, `net_mrr_change`,
`total_mrr`, `prev_total_mrr`, `mom_change`

```sql
-- Step F: Full Final query — add LAG for MoM change
WITH new_mrr AS (
    SELECT
        DATE_TRUNC('month', start_date)               AS month,
        ROUND(SUM(
            CASE
                WHEN billing_cycle = 'Annual'
                    THEN seats * price_per_seat * (1 - discount_percent / 100.0) / 12
                ELSE
                     seats * price_per_seat * (1 - discount_percent / 100.0)
            END
        ), 2)                                         AS new_mrr
    FROM subscriptions
    GROUP BY DATE_TRUNC('month', start_date)
),
churned_mrr AS (
    SELECT
        DATE_TRUNC('month', cancelled_date)           AS month,
        ROUND(SUM(
            CASE
                WHEN billing_cycle = 'Annual'
                    THEN seats * price_per_seat * (1 - discount_percent / 100.0) / 12
                ELSE
                     seats * price_per_seat * (1 - discount_percent / 100.0)
            END
        ), 2)                                         AS churned_mrr
    FROM subscriptions
    WHERE cancelled_date IS NOT NULL
    GROUP BY DATE_TRUNC('month', cancelled_date)
),
monthly_mrr AS (
    SELECT
        COALESCE(n.month, c.month)                              AS month,
        COALESCE(n.new_mrr, 0)                                  AS new_mrr,
        COALESCE(c.churned_mrr, 0)                              AS churned_mrr,
        ROUND(COALESCE(n.new_mrr, 0) - COALESCE(c.churned_mrr, 0), 2) AS net_mrr_change,
        ROUND(SUM(
            COALESCE(n.new_mrr, 0) - COALESCE(c.churned_mrr, 0)
        ) OVER (ORDER BY COALESCE(n.month, c.month)), 2)       AS total_mrr
    FROM new_mrr n
    FULL OUTER JOIN churned_mrr c ON n.month = c.month
)
SELECT
    TO_CHAR(month, 'YYYY-MM')                               AS month,
    new_mrr,
    churned_mrr,
    net_mrr_change,
    total_mrr,
    LAG(total_mrr) OVER (ORDER BY month)                    AS prev_total_mrr,
    ROUND(total_mrr - LAG(total_mrr) OVER (ORDER BY month), 2) AS mom_change
FROM monthly_mrr
ORDER BY month;
```

